{
  "name": "jj",
  "private": true,
  "version": "1.0.0",
  "description": "J&J — a shedding card game for 2–10 players",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"vite\" \"npm run dev:server\"",
    "start:server": "tsx server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.18.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.5"
  }
}
